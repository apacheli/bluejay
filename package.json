{
  "name": "bluejay",
  "description": "Building static pages made easy.",
  "version": "0.9.1-beta",
  "scripts": {
    "build": "BLUEJAY_COMMAND=build bun lib/main.js src/main.js",
    "serve": "BLUEJAY_COMMAND=serve NODE_ENV=development bun lib/main.js src/main.js",
    "serve:production": "BLUEJAY_COMMAND=serve bun lib/main.js src/main.js"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13"
  },
  "peerDependencies": {
    "@apacheli/jsx": "https://github.com/apacheli/jsx",
    "lightningcss": "^1.32.0"
  }
}
